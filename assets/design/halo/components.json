{"version":"2.6","theme":{"Mode":"Light"},"components":[{"name":"Button/Default","type":"frame","reusable":true,"use":"primary_cta","tokens":["$--primary","$--primary-foreground","$--radius-pill"],"children":[{"name":"Leading Icon","type":"frame","optional":true,"child":{"type":"icon_font","role":"icon"}},{"name":"Button","type":"text","role":"label"}],"logic":"主按钮骨架，可带前置图标和文案"},{"name":"Button/Secondary","type":"ref","ref":"Button/Default","use":"secondary_cta","overrides":["fill->$--secondary","Leading Icon.fill->$--secondary-foreground","Button.fill->$--secondary-foreground"],"logic":"和主按钮同骨架，只降强调层级"},{"name":"Button/Outline","type":"ref","ref":"Button/Default","use":"low_emphasis_action","overrides":["fill->[]","stroke.fill->$--input","Leading Icon.fill->$--foreground","Button.fill->$--foreground"],"logic":"弱强调动作，保留按钮骨架"},{"name":"Icon Button/Default","type":"ref","ref":"Button/Default","use":"tool_action","overrides":["hide->Button","padding->10"],"logic":"只保留图标，不承担主CTA"},{"name":"Input Group/Default","type":"frame","reusable":true,"use":"labeled_input","tokens":["$--accent","$--border","$--muted-foreground","$--radius-pill"],"children":[{"name":"Label Text","type":"frame","child":{"type":"text","role":"label"}},{"name":"Input","type":"frame","child":{"type":"text","name":"Input Value","role":"placeholder_or_value"}}],"logic":"完整输入区，包含标签与输入壳"},{"name":"Input Group/Filled","type":"ref","ref":"Input Group/Default","use":"labeled_input_with_value","overrides":["Input Value.content->Input Value","Input Value.fill->$--foreground"],"logic":"已填写态只改内容和值颜色"},{"name":"Select Group/Default","type":"frame","reusable":true,"use":"labeled_select","tokens":["$--accent","$--border","$--radius-pill"],"children":[{"name":"Label Text","type":"frame","child":{"type":"text","role":"label"}},{"name":"Select Trigger","type":"frame","children":["Select option","icon_font"]}],"logic":"正式表单选择器，触发器右侧保留下拉图标"},{"name":"Checkbox Description/Checked","type":"frame","reusable":true,"use":"multi_select_with_description","children":[{"name":"Checkbox","type":"ref","ref":"Checkbox/Checked"},{"name":"Text and supporting text","type":"frame","children":["Label Text","Supporting text"]}],"logic":"多选项，可附标题与辅助说明"},{"name":"Checkbox Description/Unchecked","type":"ref","ref":"Checkbox Description/Checked","use":"multi_select_with_description","overrides":["Checkbox/Checked->Checkbox/Unchecked"],"logic":"未选中态只切换勾选框状态"},{"name":"Radio Description/Selected","type":"frame","reusable":true,"use":"single_select_with_description","children":[{"name":"radio","type":"ref","ref":"Radio/Selected"},{"name":"Text and supporting text","type":"frame","children":["Label Text","Supporting text"]}],"logic":"互斥单选，适合套餐或方案选择"},{"name":"Radio Description/Unselected","type":"ref","ref":"Radio Description/Selected","use":"single_select_with_description","overrides":["Radio/Selected->Radio/Unselected"],"logic":"未选中态只切换单选状态"},{"name":"Switch/Checked","type":"frame","reusable":true,"use":"boolean_toggle","tokens":["$--primary","$--primary-foreground","$--radius-pill"],"children":[{"name":"switch","type":"frame","children":["dot"]},{"name":"Switch Label","type":"text"}],"logic":"即时开关，开启态滑块在右侧"},{"name":"Switch/Unchecked","type":"ref","ref":"Switch/Checked","use":"boolean_toggle","overrides":["switch.fill->$--input","switch.justifyContent->start"],"logic":"关闭态滑块回到左侧"},{"name":"Accordion/Open","type":"frame","reusable":true,"use":"faq_item","children":[{"name":"Accordion Trigger","type":"frame","children":["Accordion Trigger","Icon"]},{"name":"Accordion Content","type":"frame","child":{"type":"text","role":"body"}}],"logic":"FAQ或可折叠说明，打开态显示正文"},{"name":"Accordion/Closed","type":"ref","ref":"Accordion/Open","use":"faq_item","overrides":["Icon.iconFontName->chevron-down","hide->Accordion Content"],"logic":"关闭态隐藏正文"},{"name":"Card","type":"frame","reusable":true,"use":"content_container","tokens":["$--card","$--border","$--radius-l"],"slots":["Card Header","Card Content","Card Actions"],"logic":"通用卡片骨架，默认三段式承载内容"},{"name":"Alert/Info","type":"frame","reusable":true,"use":"status_message","tokens":["$--color-info","$--color-info-foreground"],"children":[{"name":"Icon","type":"frame","child":{"type":"icon_font","role":"status_icon"}},{"name":"contents","type":"frame","children":["Alert Title","Alert Description"]}],"logic":"状态提示，不承载长文"},{"name":"Alert/Success","type":"ref","ref":"Alert/Info","use":"status_message","overrides":["fill->$--color-success","Icon.iconFontName->shield-check","Icon.fill->$--color-success-foreground","Alert Title.fill->$--color-success-foreground","Alert Description.fill->$--color-success-foreground"],"logic":"成功态沿用同一提示骨架"},{"name":"Tabs","type":"frame","reusable":true,"use":"in_module_navigation","tokens":["$--card","$--input","$--radius-pill"],"children":["Tab Item/Active","Tab Item/Inactive"],"logic":"模块内切换，不替代整站导航"},{"name":"Pagination","type":"frame","reusable":true,"use":"list_pagination","children":["Previous Button","Page Numbers Slot","Next Button"],"logic":"列表翻页，内部页码复用 Pagination Item/Active 与 Pagination Item/Default"}]}
