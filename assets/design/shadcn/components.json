{"version":"2.6","theme":{"Mode":"Light"},"components":[{"name":"Button/Default","type":"frame","reusable":true,"use":"primary_cta","tokens":["$--primary","$--primary-foreground","$--radius-m"],"children":[{"name":"Leading Icon","type":"frame","optional":true,"child":{"type":"icon_font","role":"icon"}},{"name":"Button","type":"text","role":"label"}],"logic":"主按钮骨架；用于提交、继续、确认；同一区块默认只保留一个主 CTA"},{"name":"Button/Secondary","type":"ref","ref":"Button/Default","use":"secondary_action","overrides":{"fill":"$--secondary","descendants":{"Button":{"fill":"$--secondary-foreground"},"Leading Icon":{"child":{"fill":"$--secondary-foreground"}}}},"logic":"次级动作；用于返回、取消、补充入口；不要承担唯一转化动作"},{"name":"Button/Outline","type":"ref","ref":"Button/Default","use":"bounded_secondary_action","overrides":{"fill":"$--background","stroke":{"fill":"$--border"},"descendants":{"Button":{"fill":"$--foreground"},"Leading Icon":{"child":{"fill":"$--foreground"}}}},"logic":"需要边界感但不抢主次时使用；常用于卡片操作、工具条操作"},{"name":"Button/Ghost","type":"ref","ref":"Button/Outline","use":"low_emphasis_action","overrides":{"stroke":{"enabled":false}},"logic":"最低强调按钮；用于行内工具或列表轻操作；不要与主 CTA 混用为同级主动作"},{"name":"Icon Button/Default","type":"ref","ref":"Button/Default","use":"tool_action","overrides":{"width":40,"height":40,"padding":[0,0,0,0],"descendants":{"Button":{"enabled":false}}},"logic":"纯工具动作；适用于搜索、更多、关闭；不要替代带文案按钮"},{"name":"Badge/Default","type":"frame","reusable":true,"use":"status_tag","tokens":["$--primary","$--primary-foreground","$--radius-pill"],"children":[{"name":"Badge","type":"text","role":"label"}],"logic":"轻量标签；用于状态、分类、版本；不要作为按钮或分页项"},{"name":"Alert/Default","type":"frame","reusable":true,"use":"status_feedback","tokens":["$--card","$--border","$--foreground","$--muted-foreground","$--radius-l"],"children":[{"name":"Icon Container","type":"frame","child":{"type":"icon_font","role":"status_icon"}},{"name":"Text Container","type":"frame","children":[{"name":"Alert Title","type":"text","role":"title"},{"name":"Alert Description","type":"text","role":"description"}]}],"logic":"状态反馈容器；用于说明、提醒、错误提示；不要替代正文内容卡片"},{"name":"Input Group/Default","type":"frame","reusable":true,"use":"labeled_input","tokens":["$--background","$--input","$--foreground","$--muted-foreground","$--radius-m"],"children":[{"name":"Label Text","type":"frame","child":{"type":"text","role":"label"}},{"name":"Input","type":"frame","child":{"type":"text","name":"Input Value","role":"placeholder_or_value"}}],"logic":"完整输入区；适用于单行表单；优先统一标签、输入壳和占位文案结构"},{"name":"Input Group/Filled","type":"ref","ref":"Input Group/Default","use":"labeled_input_filled","overrides":{"descendants":{"Input Value":{"fill":"$--foreground","content":"Value"}}},"logic":"已填写态；只覆盖输入值和文字颜色，不复制整套输入骨架"},{"name":"Textarea Group/Default","type":"frame","reusable":true,"use":"labeled_multiline_input","tokens":["$--background","$--input","$--foreground","$--muted-foreground","$--radius-m"],"children":[{"name":"Label Text","type":"frame","child":{"type":"text","role":"label"}},{"name":"Textarea","type":"frame","child":{"type":"text","name":"Input Value","role":"placeholder_or_value"}}],"logic":"多行输入；适用于备注、说明、反馈；不要用来承载长正文内容区"},{"name":"Select Group/Default","type":"frame","reusable":true,"use":"labeled_select","tokens":["$--background","$--input","$--foreground","$--muted-foreground","$--radius-m"],"children":[{"name":"Label Text","type":"frame","child":{"type":"text","role":"label"}},{"name":"Select Trigger","type":"frame","children":[{"name":"Select option","type":"text","role":"placeholder_or_value"},{"name":"Trailing Icon","type":"icon_font","role":"chevron"}]}],"logic":"离散选项选择器；适用于有限选项；不要与自由输入混用表达同一字段"},{"name":"Checkbox/Checked","type":"frame","reusable":true,"use":"multi_select_item","tokens":["$--primary","$--primary-foreground","$--border","$--radius-s"],"children":[{"name":"Checkbox","type":"frame","child":{"name":"Indicator","type":"icon_font","role":"check"}},{"name":"Label Text","type":"text","role":"label"}],"logic":"多选项骨架；用于列表勾选与复选表单；同一组不要与 Radio 混用"},{"name":"Checkbox/Unchecked","type":"ref","ref":"Checkbox/Checked","use":"multi_select_item_unchecked","overrides":{"descendants":{"Checkbox":{"fill":"$--background","stroke":{"fill":"$--input"}},"Indicator":{"enabled":false}}},"logic":"未勾选态；复用选中态骨架，仅去掉勾选标记与主色填充"},{"name":"Radio/Selected","type":"frame","reusable":true,"use":"single_select_item","tokens":["$--primary","$--input","$--foreground"],"children":[{"name":"Radio","type":"frame","child":{"name":"Circle","type":"rectangle","role":"indicator"}},{"name":"Label Text","type":"text","role":"label"}],"logic":"单选项骨架；用于互斥选择；不要与 Checkbox 表达同一组决策"},{"name":"Radio/Unselected","type":"ref","ref":"Radio/Selected","use":"single_select_item_unselected","overrides":{"descendants":{"Circle":{"enabled":false},"Radio":{"fill":"$--background","stroke":{"fill":"$--input"}}}},"logic":"未选中态；保留同一语义骨架，只关闭内部圆点"},{"name":"Switch/Checked","type":"frame","reusable":true,"use":"instant_toggle","tokens":["$--primary","$--background","$--foreground","$--radius-pill"],"children":[{"name":"Switch","type":"frame","child":{"name":"thumb","type":"rectangle","role":"thumb"}},{"name":"Switch Label","type":"text","role":"label"}],"logic":"即时开关；用于设置启停；不要拿来表达提交后才生效的表单确认"},{"name":"Switch/Unchecked","type":"ref","ref":"Switch/Checked","use":"instant_toggle_unchecked","overrides":{"descendants":{"Switch":{"fill":"$--secondary","justifyContent":"start"}}},"logic":"关闭态；沿用同一轨道结构，只切换轨道颜色与 thumb 位置"},{"name":"Card","type":"frame","reusable":true,"use":"content_container","tokens":["$--card","$--card-foreground","$--border","$--radius-l"],"slots":["Card Header","Card Content","Card Actions"],"logic":"通用卡片骨架；适用于功能说明、摘要、价格、设置块；默认三段式理解"},{"name":"Tab Item/Active","type":"frame","reusable":true,"use":"in_module_navigation_active","tokens":["$--background","$--foreground","$--radius-xs"],"children":[{"name":"Label Selected","type":"text","role":"label"}],"logic":"激活标签项；仅用于模块内部切换，不用于主导航"},{"name":"Tab Item/Inactive","type":"ref","ref":"Tab Item/Active","use":"in_module_navigation_inactive","overrides":{"fill":"transparent","effect":[],"descendants":{"Label Selected":{"fill":"$--muted-foreground"}}},"logic":"未激活标签项；复用激活态骨架，只降低强调层级"},{"name":"Tabs","type":"frame","reusable":true,"use":"in_module_navigation","tokens":["$--secondary","$--radius-m"],"children":["Tab Item/Active","Tab Item/Inactive"],"logic":"模块内分段切换；不要替代站点导航、分页或筛选面包屑"},{"name":"Pagination Item/Active","type":"frame","reusable":true,"use":"pagination_current","tokens":["$--background","$--foreground","$--border","$--radius-m"],"children":[{"name":"Page Label","type":"text","role":"page_number"}],"logic":"当前页页码；用于列表翻页高亮"},{"name":"Pagination Item/Default","type":"ref","ref":"Pagination Item/Active","use":"pagination_item","overrides":{"fill":"transparent","effect":[],"descendants":{"Page Label":{"fontWeight":"normal"}}},"logic":"普通页码；与当前页共用骨架，只降低层级"},{"name":"Pagination","type":"frame","reusable":true,"use":"list_pagination","children":["Previous Button","Page Numbers Slot","Next Button"],"logic":"列表翻页；内部复用 Pagination Item/Active 与 Pagination Item/Default；不要用作 Tabs 或主导航"},{"name":"Sidebar Item/Active","type":"frame","reusable":true,"use":"sidebar_nav_item_active","tokens":["$--sidebar-accent","$--sidebar-foreground","$--radius-m"],"children":[{"name":"Item Content Left","type":"frame","children":[{"name":"Leading Icon","type":"frame","child":{"type":"icon_font","role":"icon"}},{"name":"Label","type":"text","role":"label"}]},{"name":"Item Content Right","type":"frame","optional":true,"child":{"name":"Trailing Icon","type":"icon_font","role":"icon"}}],"logic":"侧栏激活项；适用于工作台与文档台；不要直接拿来当官网主 CTA"},{"name":"Sidebar Item/Default","type":"ref","ref":"Sidebar Item/Active","use":"sidebar_nav_item_default","overrides":{"fill":"transparent"},"logic":"侧栏默认项；与激活项保持同一信息结构，只去掉高亮底色"},{"name":"Sidebar","type":"frame","reusable":true,"use":"workspace_sidebar","tokens":["$--sidebar","$--sidebar-border","$--sidebar-foreground","$--sidebar-accent","$--radius-m"],"slots":["Sidebar Header","Sidebar Content","Sidebar Footer"],"children":["Sidebar Item/Active","Sidebar Item/Default"],"logic":"侧栏容器；适用于后台、工作台、文档台；产品官网默认少用，避免和 Tabs、顶部导航混成多套主导航"}]}
